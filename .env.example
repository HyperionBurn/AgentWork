# ============================================================
# AgentWork — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Arc Testnet ---
ARC_CHAIN_ID=5042002
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_GATEWAY_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_EXPLORER=https://testnet.arcscan.io/tx/
ARC_FAUCET=https://faucet.circle.com

# --- Wallets (NEVER commit real keys) ---
ORCHESTRATOR_PRIVATE_KEY=0x_your_orchestrator_key
RESEARCH_AGENT_WALLET=0x_your_research_agent_address
CODE_AGENT_WALLET=0x_your_code_agent_address
TEST_AGENT_WALLET=0x_your_test_agent_address
REVIEW_AGENT_WALLET=0x_your_review_agent_address

# --- Seller Wallet (dashboard receives payments via x402) ---
SELLER_WALLET=0x_your_dashboard_receiving_wallet

# --- Deployed Contracts (fill after deploy) ---
IDENTITY_REGISTRY_ADDRESS=0x_
REPUTATION_REGISTRY_ADDRESS=0x_
AGENT_ESCROW_ADDRESS=0x_
PAYMENT_SPLITTER_ADDRESS=0x_
SPENDING_LIMITER_ADDRESS=0x_

# --- Supabase (dashboard uses NEXT_PUBLIC_ prefixed vars) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (orchestrator uses these directly) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Agent Pricing (USDC) - SDK requires dollar prefix ---
RESEARCH_AGENT_PRICE=$0.005
CODE_AGENT_PRICE=$0.005
TEST_AGENT_PRICE=$0.005
REVIEW_AGENT_PRICE=$0.005

# --- Agent Ports ---
RESEARCH_AGENT_PORT=4021
CODE_AGENT_PORT=4022
TEST_AGENT_PORT=4023
REVIEW_AGENT_PORT=4024
ORCHESTRATOR_PORT=4030
DASHBOARD_PORT=3000

# --- Orchestrator ---
DEMO_TASK=Build a REST API with user authentication, CRUD endpoints, and unit tests
DEMO_RUNS=1
USE_PARALLEL=true
USE_REAL_LLM=false
USE_LLM_DECOMPOSER=false

# --- LLM Integration (optional — for real LLM responses) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Agent URLs (for Docker / orchestrator) ---
RESEARCH_AGENT_URL=http://localhost:4021
CODE_AGENT_URL=http://localhost:4022
TEST_AGENT_URL=http://localhost:4023
REVIEW_AGENT_URL=http://localhost:4024

# --- Circle Gateway API (for dashboard seller-side x402) ---
GATEWAY_URL=https://gateway-api-testnet.circle.com
