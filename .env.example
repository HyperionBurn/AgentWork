# ============================================================
# AgentWork — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Arc Testnet ---
ARC_CHAIN_ID=5042002
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_GATEWAY_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_EXPLORER=https://testnet.arcscan.app/tx/
ARC_FAUCET=https://faucet.circle.com

# --- Wallets (NEVER commit real keys) ---
ORCHESTRATOR_PRIVATE_KEY=0x_your_orchestrator_key
RESEARCH_AGENT_WALLET=0x_your_research_agent_address
CODE_AGENT_WALLET=0x_your_code_agent_address
TEST_AGENT_WALLET=0x_your_test_agent_address
REVIEW_AGENT_WALLET=0x_your_review_agent_address

# --- Seller Wallet (dashboard receives payments via x402) ---
SELLER_WALLET=0x_your_dashboard_receiving_wallet

# --- Deployed Contracts (fill after deploy) ---
IDENTITY_REGISTRY_ADDRESS=0x_
REPUTATION_REGISTRY_ADDRESS=0x_
AGENT_ESCROW_ADDRESS=0x_
PAYMENT_SPLITTER_ADDRESS=0x_
SPENDING_LIMITER_ADDRESS=0x_

# --- Supabase (dashboard uses NEXT_PUBLIC_ prefixed vars) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (orchestrator uses these directly) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Agent Pricing (USDC) - SDK requires dollar prefix ---
RESEARCH_AGENT_PRICE=$0.005
CODE_AGENT_PRICE=$0.005
TEST_AGENT_PRICE=$0.005
REVIEW_AGENT_PRICE=$0.005

# --- Agent Ports ---
RESEARCH_AGENT_PORT=4021
CODE_AGENT_PORT=4022
TEST_AGENT_PORT=4023
REVIEW_AGENT_PORT=4024
ORCHESTRATOR_PORT=4030
DASHBOARD_PORT=3000

# --- Orchestrator ---
DEMO_TASK=Build a REST API with user authentication, CRUD endpoints, and unit tests
DEMO_RUNS=3
USE_PARALLEL=true
USE_LLM_DECOMPOSER=false

# --- LLM Integration (optional — for real LLM responses) ---
# Supported providers: openai, gemini, featherless, ai-ml-api
LLM_PROVIDER=openai
USE_REAL_LLM=false

# OpenAI / AI/ML API (compatible with OpenAI SDK)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Gemini API (Google AI Studio)
# Get key: https://makersuite.google.com/app/apikey
# Docs: https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash  # Options: gemini-3-flash, gemini-3-pro

# Featherless API
# Get key: https://featherless.ai/ (signup via hackathon setup guide)
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# AI/ML API (supports multiple models including Gemini, Claude)
# Get key: https://ai-ml-api.com/ + use hackathon promo code
AI_ML_API_KEY=
AI_ML_MODEL=gemini/gemini-3-flash

# --- Agent URLs (for Docker / orchestrator) ---
RESEARCH_AGENT_URL=http://localhost:4021
CODE_AGENT_URL=http://localhost:4022
TEST_AGENT_URL=http://localhost:4023
REVIEW_AGENT_URL=http://localhost:4024

# --- Circle Gateway API (for dashboard seller-side x402) ---
GATEWAY_URL=https://gateway-api-testnet.circle.com

# ============================================================
# Game-Changing Features (GC1-GC5)
# ============================================================

# GC1: Gemini Function Calling for Autonomous Orchestrator
# Uses Gemini 3 Flash to decide task routing, escrow creation, pricing, reputation
# Targets Google/Gemini Prize ($4,400)
USE_GEMINI_ORCHESTRATOR=false

# GC2: Token-Aware Streaming Nanopayments
# Extends revenue streaming with per-token tracking
USE_TOKEN_STREAMING=false

# GC3: Agent Reasoning Feed
# Writes AI decision reasoning to Supabase for dashboard visualization
USE_REASONING_FEED=true

# GC5: Live Economic Counter
# 7-chain cost comparison on dashboard (Arc, Solana, Polygon, Base, Optimism, Arbitrum, Ethereum)
USE_LIVE_ECONOMIC_COUNTER=true

# ============================================================
# Game-Changing Features (GC6-GC11)
# ============================================================

# GC6: A2A Multi-Agent Chaining
# Agents call other agents in chain (research→code→test) via x402 payments
USE_A2A_CHAINING=true

# GC7: Payment Receipt Generation
# SHA-256 Merkle tree receipts for every payment batch
# Receipts are generated automatically in orchestrator run loop
USE_RECEIPTS=true

# GC8: Spending Analytics Dashboard
# Per-agent spending breakdown, time-series charts, budget projections
USE_SPENDING_ANALYTICS=true

# GC9: Cross-Chain Withdrawal (Circle Bridge Kit)
# CCTP-powered USDC bridge from Arc → Base/Ethereum/Arbitrum/etc.
# Requires ORCHESTRATOR_PRIVATE_KEY to be set for real transfers
# Falls back to simulated mode if Bridge Kit is unavailable
USE_CROSS_CHAIN_WITHDRAW=true

# GC10: Agent Reputation Feed
# Post-task feedback scoring, reputation history, trust signals
USE_REPUTATION_FEED=true

# GC11: SLA Compliance Engine
# Per-agent SLA evaluation (response time, success rate, payment accuracy)
# Set to "true" to evaluate SLAs after each orchestrator run
USE_SLA_ENGINE=true
